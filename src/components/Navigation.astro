---
import Button from '../components/ui/Button.astro'
import Badge from '../components/ui/Badge.astro'

/** Main menu items */
const navLinks: { label: string; href: string }[] = [
  // { label: 'Home', href: '/' },
  { label: 'About', href: '/' },
  { label: 'Work', href: '/#work' },
  // { label: 'Library', href: '/library/' },
  { label: 'Contact', href: '/#contact' },
  { label: 'Journal', href: '/journal/' },
  // { label: 'Notes', href: '/notes/', icon: 'tabler:note' },
]

/** Library links to content collections */
// const libraryLinks: { label: string; href: string; icon: string }[] = [
//   { label: 'Bookmarks', href: '/bookmarks', icon: 'tabler:bookmarks' },
//   { label: 'Books', href: '/books', icon: 'tabler:book' },
//   { label: 'Movies', href: '/movies', icon: 'tabler:movie' },
//   { label: 'TV Shows', href: '/tv-shows', icon: 'tabler:device-tv-old' },
//   { label: 'Games', href: '/games', icon: 'tabler:device-gamepad-2' },
//   { label: 'Events', href: '/events', icon: 'tabler:ticket' },
//   { label: 'Uses', href: '/uses', icon: 'tabler:devices-2' },
// ]

/** Test if a link is pointing to the current page. */
const isCurrentPage = (href: string) => {
  let pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '')
  if (pathname.at(0) !== '/') pathname = '/' + pathname
  if (pathname.at(-1) !== '/') pathname += '/'
  // Hash links (e.g. /#contact) are only active via scroll script on the index page
  if (href.includes('#')) return false
  return pathname === href || (href !== '/' && pathname.startsWith(href))
}
---

<div class='flex flex-col gap-2 px-4 pt-4 pb-2 w-full leading-tight border-b border-ui-1 text-tx-3'>
  <div class='grid grid-cols-1 gap-2 pb-4 max-w-600 m-auto w-full md:grid-cols-2 md:text-xl'>
    <div>
      <div class='flex justify-between gap-1 md:flex-col md:items-start md:gap-1.5'>
        <p class='text-tx-1'>Brody MacLean</p>
        <!-- <Button magnetic href='mailto:hello@brody.com' class='text-bg-2 bg-tx-1 hover:bg-tx-2'
          >Let's chat</Button
        > -->
        <Badge class='-mt-1 md:mt-0 md:flex-auto'>
          <span> Available <span class='max-sm:hidden'>for my next role</span> from July '26</span>
        </Badge>
      </div>
    </div>
    <div class='max-w-5xl'>
      A designer and leader with 15+ years shaping digital products and the teams that build them<span
        class='hidden lg:inline'
      >
        — driven by craft, and a servant leadership approach</span
      >.
    </div>
  </div>
</div>
<nav class='sticky top-0 z-10 w-full px-4 py-4 text-base font-medium bg-bg-1 text-tx-3'>
  <ul class='flex m-auto nav-items max-w-600'>
    {
      navLinks.map(({ label, href }) => (
        <li>
          <a
            aria-current={isCurrentPage(href) ? 'page' : null}
            data-nav-href={href}
            class={
              isCurrentPage(href)
                ? 'link text-tx-1 bg-bg-2 inline-flex h-8 items-center gap-3 rounded-lg px-2'
                : 'link hover:text-tx-1 inline-flex h-8 items-center gap-3 rounded-lg px-2'
            }
            href={href}
          >
            {/* <Icon size={16} name={icon} class='' /> */}
            {label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<script>
  function initAnchorNav() {
    // Only run on the homepage
    if (window.location.pathname !== '/' && window.location.pathname !== import.meta.env.BASE_URL)
      return

    const allNavLinks = document.querySelectorAll<HTMLAnchorElement>('[data-nav-href]')
    const anchorLinks = document.querySelectorAll<HTMLAnchorElement>('[data-nav-href*="#"]')
    if (!anchorLinks.length) return

    // Build ordered map of hash -> nav link
    const hashToLink = new Map<string, HTMLAnchorElement>()
    anchorLinks.forEach((link) => {
      const hash = link.getAttribute('data-nav-href')?.split('#')[1]
      if (hash) hashToLink.set(hash, link)
    })

    const aboutLink = document.querySelector<HTMLAnchorElement>('[data-nav-href="/"]')
    const activeClass = ['text-tx-1', 'bg-bg-2']
    const inactiveClass = ['hover:text-tx-1']

    function setActive(link: HTMLAnchorElement | null) {
      allNavLinks.forEach((l) => {
        l.classList.remove(...activeClass)
        l.classList.add(...inactiveClass)
        l.removeAttribute('aria-current')
      })
      if (link) {
        link.classList.add(...activeClass)
        link.classList.remove(...inactiveClass)
        link.setAttribute('aria-current', 'page')
      }
    }

    function updateActive() {
      const scrollY = window.scrollY
      const viewportH = window.innerHeight
      const pageH = document.documentElement.scrollHeight

      // Near bottom of page → Contact active
      if (scrollY + viewportH >= pageH - 80) {
        setActive(hashToLink.get('contact') ?? null)
        return
      }

      let activeLink: HTMLAnchorElement | null = null

      hashToLink.forEach((link, hash) => {
        const section = document.getElementById(hash)
        if (!section) return

        // If the section has a sticky heading, activate when it sticks
        const heading = section.querySelector<HTMLElement>('h2')
        if (heading && getComputedStyle(heading).position === 'sticky') {
          const stickyTop = parseFloat(getComputedStyle(heading).top) || 0
          if (heading.offsetTop - stickyTop - 24 <= scrollY) activeLink = link
        } else {
          // General trigger: section top crosses 45% down the viewport
          if (section.offsetTop <= scrollY + viewportH * 0.45) activeLink = link
        }
      })

      // Fall back to About when above all anchor sections
      setActive(activeLink ?? aboutLink ?? null)
    }

    window.addEventListener('scroll', updateActive, { passive: true })
    updateActive()
  }

  initAnchorNav()
  document.addEventListener('astro:page-load', initAnchorNav)
</script>
