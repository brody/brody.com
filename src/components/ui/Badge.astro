---
interface Props {
  class?: string
}

const { class: className, ...rest } = Astro.props
---

<span
  class:list={[
    'bg-bg-2/70 text-tx-2 inline-flex h-7 items-center gap-2 rounded-full px-3 text-sm',
    className,
  ]}
  {...rest}
>
  <div class='pulse-dot' aria-hidden='true'></div>
  <slot />
</span>

<style>
  .pulse-dot {
    position: relative;
    display: inline-block;
    width: 0.5em;
    height: 0.5em;
    flex-shrink: 0;
  }

  .pulse-dot::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background-color: var(--color-green-500);
    border: 0.5px solid white;
  }

  .pulse-dot::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background-color: var(--color-green-500);
    animation: pulse-ring 2.5s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  @keyframes pulse-ring {
    0% {
      transform: scale(1);
      opacity: 0.6;
    }
    70% {
      transform: scale(3);
      opacity: 0;
    }
    100% {
      transform: scale(1);
      opacity: 0;
    }
  }
</style>
