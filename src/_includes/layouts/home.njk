---
layout: layouts/base.njk
---

{% block content %}
  <main id="main-content" tabindex="-1">
    <div class="max-w-2xl px-4 mx-auto sm:px-6 lg:px-8">
      <h1 class="text-3xl font-bold leading-tight text-neutral-50">
        {{ intro.title }}
      </h1>
    </div>
    <div class="max-w-2xl px-4 mx-auto sm:px-6 lg:px-8">
      <div class="py-8 leading-8 text-neutral-300">
        <p class="text-xl">{{ intro.desc }}</p>
      </div>
      <div class="prose prose-lg prose-neutral text-neutral-300">
        {{ content | safe }}
      </div>
    </div>
  </main>
{% endblock %}