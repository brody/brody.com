---
import BaseLayout from '../layouts/BaseLayout.astro'
// import MarkdownPostLayout from '../layouts/MarkdownPostLayout.astro'
const pageTitle = 'About Me'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import brandLaunch from '/public/assets/images/brand.jpg'
import sydney from '~/pages/about/_images/sydney.png'
import hero1 from '~/pages/about/_images/hero1.png'
import hero2 from '~/pages/about/_images/hero2.png'
import hero3 from '~/pages/about/_images/hero3.png'
import marion from 'public/assets/work/automation/redesign.png'
import prospaRedesign from 'public/assets/work/prospa-rebrand/Prospa.png'
import salt from 'public/assets/work/salt/salt-square.png'
import prospaTokens from 'public/assets/journal/prospa-tokens/og-square.png'
import mitti from 'public/assets/work/mitti/square.png'
import mittiRewards from 'public/assets/work/mitti/rewards.png'
import venom from 'public/assets/work/jobadder/uikit.png'
import designJam from 'public/assets/work/jobadder/designjam.png'
import jobadderNav from 'public/assets/work/jobadder-nav/nav-square.png'
import deputyWorkshop from 'public/assets/work/deputy/workshop.png'
import deputyHackathon from 'public/assets/work/deputy/hackathon.png'
import deputyFigma from 'public/assets/work/deputy/figma.png'
---

<BaseLayout>
  <section class='pt-4 system-grid md:pt-8'>
    <div class='col-start-1 col-end-13 pb-12 md:pb-20 lg:col-start-7 lg:pb-30'>
      <h1 class='max-w-sm m-0 text-tx-3 text-h1 md:max-w-lg lg:max-w-2xl'>
        <span class='word-in text-tx-0' style='animation-delay: 0ms'>Brody</span>{' '}
        <span class='word-in' style='animation-delay: 60ms'>is</span>{' '}
        <span class='word-in' style='animation-delay: 90ms'>a</span>{' '}
        <span class='word-in' style='animation-delay: 120ms'>multi-</span><span class='word-in' style='animation-delay: 150ms'>disciplinary</span>{' '}
        <span class='word-in text-tx-0' style='animation-delay: 180ms'>design</span>{' '}
        <span class='word-in' style='animation-delay: 240ms'>leader</span>{' '}
        <span class='word-in' style='animation-delay: 270ms'>based</span>{' '}
        <span class='word-in' style='animation-delay: 300ms'>in</span>{' '}
        <span class='word-in' style='animation-delay: 330ms'>
          <Image
            src={sydney}
            alt='Sydney Opera House'
            class='-mt-1 inline-block h-[0.85em] w-auto'
            width={100}
            height={54}
            quality={90}
            densities={[2, 3]}
          />
        </span>{' '}
        <span class='word-in text-tx-0' style='animation-delay: 390ms'>Sydney,</span>{' '}
        <span class='word-in' style='animation-delay: 450ms'>Australia.</span>
      </h1>
    </div>
    <div class='grid col-span-6 col-start-1 grid-rows-2 row-span-2 gap-2 aspect-square'>
      <Image
        src={hero1}
        alt='SafetyCulture team at Figma event'
        class='object-cover w-full h-full rounded-xl md:rounded-2xl'
        width={1200}
        height={600}
        quality={80}
        densities={[2, 3]}
      />
      <Image
        src={hero2}
        alt='Brody MacLean presenting at the Prospa brand launch'
        class='object-cover w-full h-full rounded-xl md:rounded-2xl'
        width={1200}
        height={600}
        quality={80}
        densities={[2, 3]}
      />
    </div>
    <Image
      src={hero3}
      alt='Brody MacLean'
      class='object-cover col-span-6 col-start-7 row-span-2 aspect-square rounded-xl md:rounded-2xl'
      width={1200}
      height={1200}
      quality={80}
      densities={[2, 3]}
    />
  </section>
  <section class='py-16 border-b system-grid border-ui-1 lg:py-20'>
    <div class='col-span-12 col-start-1 md:col-span-6'>
      <h2 class='mb-4 text-2xl font-medium lg:sticky lg:top-24 lg:mb-0 lg:text-[32px]'>Intro</h2>
    </div>
    <div
      class='col-start-1 col-end-13 flex max-w-4xl flex-col gap-6 text-xl tracking-tight lg:col-start-7 lg:gap-8 lg:text-[28px]'
    >
      <p>
        With 15+ years of experience in product design, I've built a career spanning product design,
        strategy, design systems, AI features, and design leadership — working across startups,
        scale-ups, and enterprise organisations to ship high-quality, user-centred products.
      </p>
      <p>
        I'm equally comfortable leading and growing design teams as I am getting hands-on with
        components, Figma libraries, and cross-functional delivery.
      </p>
      <p>
        A natural curiosity keeps me at the intersection of design and technology, constantly
        exploring how emerging tools — particularly AI — can raise the bar for both product
        experience and design practice.
      </p>
    </div>
  </section>
  <section class='py-16 border-b system-grid border-ui-1 lg:py-28' id='work'>
    <div class='col-span-12 col-start-1 md:col-span-6'>
      <h2 class='mb-4 text-2xl font-medium lg:sticky lg:top-24 lg:mb-0 lg:text-[32px]'>
        Work highlights
      </h2>
    </div>
    <div class='grid col-start-1 col-end-13 text-lg lg:col-start-7 lg:text-xl'>
      <div class='flex flex-col gap-12 pb-12 border-b border-ui-1'>
        <div class='flex flex-col gap-6'>
          <div class='flex items-center justify-between'>
            <div class='flex h-16 w-16 items-center justify-center rounded-xl bg-[#1868DB]'>
              <svg
                width='32'
                height='32'
                viewBox='0 0 32 32'
                class='-mt-0.5'
                fill='none'
                xmlns='http://www.w3.org/2000/svg'
              >
                <path
                  d='M31.6541 30.0939L17.009 0.750905C16.7207 0.115525 16.4325 0 16.0865 0C15.7982 0 15.4522 0.115525 15.1063 0.693142C13.0306 3.98556 12.1081 7.79782 12.1081 11.7834C12.1081 17.3285 14.9333 22.5271 19.0847 30.9025C19.546 31.8267 19.8919 32 20.6991 32H30.8468C31.5964 32 32 31.7112 32 31.1336C32 30.8447 31.9423 30.6715 31.6541 30.0939ZM10.3784 16.231C9.22519 14.4982 8.87929 14.3826 8.59095 14.3826C8.30271 14.3826 8.12976 14.4982 7.61082 15.5379L0.288293 30.2094C0.0576586 30.6715 0 30.8447 0 31.0759C0 31.5379 0.403601 32 1.26847 32H11.5892C12.2811 32 12.8 31.4224 13.0882 30.3249C13.4342 28.9386 13.5495 27.7256 13.5495 26.2816C13.5495 22.2383 11.7621 18.3105 10.3784 16.231Z'
                  fill='white'
                  style='fill:white;fill-opacity:1;'></path>
              </svg>
            </div>
            <div class='px-3 py-2 text-xs font-medium rounded-full bg-bg-2 text-tx-0'>
              2024 - 2026
            </div>
          </div>
          <div>
            <h3 class='text-2xl'>Atlassian</h3>
            <h4 class='text-base'>Design Lead</h4>
          </div>
          <p class='max-w-4xl text-tx-2'>
            Led the design and integration of AI UI components within the Atlassian Design System,
            bridging AI patterns, brand principles, and front-end implementation to deliver
            accessible, production-ready controls.
          </p>
          <p class='max-w-4xl text-tx-2'>
            Owned the end-to-end component lifecycle — from high-fidelity Figma assets and visual
            specs to UX documentation and cross-team pattern adoption.
          </p>
          <p class='max-w-4xl text-tx-2'>
            Prior to this, I drove the end-to-end delivery for Automation's Business Process
            Automation initiative and a visual refresh that enabled key design OKRs and
            cross-functional business goals. Working closely with engineering, product, and design
            stakeholders, I mentored junior designers and aligned design strategy with customer
            needs and business objectives.
          </p>
        </div>
        <div class='grid grid-cols-6 gap-x-4 gap-y-6'>
          <div class='flex flex-col col-span-3 col-start-1 gap-2 md:col-span-2'>
            <video
              class='object-cover w-full aspect-square rounded-2xl'
              autoplay
              muted
              loop
              playsinline
            >
              <source src='/assets/work/rovo/rovo2-square.webm' type='video/webm' />
              <source src='/assets/work/rovo/rovo2-square.mp4' type='video/mp4' />
            </video>
            <div>
              <h4 class='text-sm'>AI Design Kit</h4>
              <p class='text-sm text-tx-2'>Design system, Figma libraries, docs</p>
            </div>
          </div>
          <div class='flex flex-col col-span-3 gap-2 md:col-span-2'>
            <video
              class='object-cover w-full aspect-square rounded-2xl'
              autoplay
              muted
              loop
              playsinline
            >
              <source src='/assets/work/rovo/rebrand.webm' type='video/webm' />
              <source src='/assets/work/rovo/rebrand.mp4' type='video/mp4' />
            </video>
            <div>
              <h4 class='text-sm'>Rovo brand refresh</h4>
              <p class='text-sm text-tx-2'>Product & UI design</p>
            </div>
          </div>
          <div class='flex flex-col col-span-3 gap-2 md:col-span-2'>
            <video
              class='object-cover w-full aspect-square rounded-2xl'
              autoplay
              muted
              loop
              playsinline
            >
              <source src='/assets/work/rovo/chat.webm' type='video/webm' />
              <source src='/assets/work/rovo/chat.mp4' type='video/mp4' />
            </video>
            <div>
              <h4 class='text-sm'>Rovo nudge and chat</h4>
              <p class='text-sm text-tx-2'>Product & UI design</p>
            </div>
          </div>
          <div class='flex flex-col col-span-3 gap-2 md:col-span-2'>
            <Image
              src={marion}
              alt='Automation redesign'
              class='object-cover w-full border border-ui-1 aspect-square rounded-2xl'
              width={390}
              height={390}
              quality={90}
              densities={[2, 3]}
            />
            <div>
              <h4 class='text-sm'>Builder redesign</h4>
              <p class='text-sm text-tx-2'>Systems and UI design</p>
            </div>
          </div>
          <div class='flex flex-col col-span-3 gap-2 md:col-span-2'>
            <video
              class='object-cover w-full border border-ui-1 aspect-square rounded-2xl'
              autoplay
              muted
              loop
              playsinline
            >
              <source src='/assets/work/automation/redesign.webm' type='video/webm' />
              <source src='/assets/work/automation/redesign.mp4' type='video/mp4' />
            </video>
            <div>
              <h4 class='text-sm'>Business Process Automation</h4>
              <p class='text-sm text-tx-2'>UX, UI design, strategy</p>
            </div>
          </div>
        </div>
      </div>
      <div class='flex flex-col gap-12 py-12 border-b border-ui-1'>
        <div class='flex flex-col gap-6'>
          <div class='flex items-center justify-between'>
            <div class='flex h-16 w-16 items-center justify-center rounded-xl bg-[#1A1A1A]'>
              <svg
                width='41'
                class='w-10'
                height='40'
                viewBox='0 0 41 40'
                fill='none'
                xmlns='http://www.w3.org/2000/svg'
              >
                <g clip-path='url(#clip0_75_350)'>
                  <path
                    d='M40.3501 24.3422V3.99822C40.3501 3.70338 40.1535 3.50682 39.8587 3.6051L34.0602 5.96382C33.7653 6.0621 33.6671 6.16038 33.6671 6.45522V20.3127C33.6671 20.6076 33.5688 20.7058 33.3722 20.8041L7.32798 31.3201C7.13142 31.4184 7.03314 31.6149 7.03314 31.8115V37.5117C7.03314 37.9049 7.2297 38.1014 7.52454 37.9049L39.957 24.8336C40.2518 24.7353 40.3501 24.5388 40.3501 24.3422ZM0.350098 13.2365V33.5805C0.350098 33.8754 0.546658 34.0719 0.841498 33.9736L6.64002 31.6149C6.83658 31.5166 6.93486 31.3201 6.93486 31.1235V17.1678C6.93486 16.8729 7.03314 16.7746 7.2297 16.6764L33.2739 6.25866C33.4705 6.16038 33.5688 5.96382 33.5688 5.76726V-0.0312652C33.5688 -0.326106 33.3722 -0.522666 33.0774 -0.424386L0.644938 12.6469C0.448378 12.8434 0.350098 12.9417 0.350098 13.2365Z'
                    fill='white'
                    style='fill:white;fill-opacity:1;'></path>
                </g>
                <defs>
                  <clipPath id='clip0_75_350'>
                    <rect width='40.7' height='39.1' fill='white' style='fill:white;fill-opacity:1;'
                    ></rect>
                  </clipPath>
                </defs>
              </svg>
            </div>
            <div class='px-3 py-2 text-xs font-medium rounded-full bg-bg-2 text-tx-0'>
              2022 - 2024
            </div>
          </div>
          <div>
            <h3 class='text-2xl'>Prospa</h3>
            <h4 class='text-base'>Design System Lead</h4>
          </div>
          <p class='max-w-4xl text-tx-2'>
            Led the design systems team at Prospa, unifying divergent design and code across
            products to significantly reduce design and development debt while driving the
            end-to-end implementation of a company-wide rebrand.
          </p>
          <p class='max-w-4xl text-tx-2'>
            Managed and grew the team through hiring, mentoring, and performance development, and
            partnered with senior leadership to shape a multi-year systems roadmap and future
            product design vision.
          </p>
        </div>

        <div class='grid grid-cols-6 gap-x-4 gap-y-6'>
          <div class='flex flex-col col-span-3 col-start-1 gap-2 md:col-span-2'>
            <Image
              src={salt}
              alt='Prospa redesign'
              class='object-cover w-full border border-ui-1 aspect-square rounded-2xl'
              width={390}
              height={390}
              quality={90}
              densities={[2, 3]}
            />
            <div>
              <h4 class='text-sm'>Salt Design System</h4>
              <p class='text-sm text-tx-2'>Brand, strategy, UI design</p>
            </div>
          </div>
          <div class='flex flex-col col-span-3 gap-2 md:col-span-2'>
            <Image
              src={prospaRedesign}
              alt='Prospa redesign'
              class='object-cover w-full border border-ui-1 aspect-square rounded-2xl'
              width={390}
              height={390}
              quality={90}
              densities={[2, 3]}
            />
            <div>
              <h4 class='text-sm'>Prospa redesign</h4>
              <p class='text-sm text-tx-2'>UI design, brand, systems, strategy</p>
            </div>
          </div>
          <div class='flex flex-col col-span-3 gap-2 md:col-span-2'>
            <Image
              src={prospaTokens}
              alt='Prospa design tokens'
              class='object-cover w-full border border-ui-1 aspect-square rounded-2xl'
              width={390}
              height={390}
              quality={90}
              densities={[2, 3]}
            />
            <div>
              <h4 class='text-sm'>
                Developing a scalable design token taxonomy for Prospa's Design System
              </h4>
              <p class='text-sm text-tx-2'>Coming soon</p>
            </div>
          </div>
        </div>
      </div>
      <div class='flex flex-col gap-12 py-12 border-b border-ui-1'>
        <div class='flex flex-col gap-6'>
          <div class='flex items-center justify-between'>
            <div
              class='flex items-center justify-center w-16 h-16 bg-white border border-ui-1 rounded-xl'
            >
              <svg
                width='44'
                height='34'
                viewBox='0 0 44 34'
                fill='none'
                xmlns='http://www.w3.org/2000/svg'
              >
                <g clip-path='url(#clip0_201_577)'>
                  <path
                    d='M41.1817 27.5806H28.4169C28.0593 29.204 26.8871 30.4909 25.3872 31.0452L38.7579 30.1741C40.0791 30.1444 41.2016 29.204 41.4598 27.9171C41.4996 27.739 41.3605 27.5806 41.1817 27.5806Z'
                    fill='#FFD700'
                    style='fill:#FFD700;fill:color(display-p3 1.0000 0.8431 0.0000);fill-opacity:1;'
                  ></path>
                  <path
                    d='M28.4172 27.5806H14.8379V27.6003C14.4207 29.6792 12.9206 31.3126 11.0034 31.9758L25.3974 31.0452C26.8973 30.4909 28.0596 29.204 28.4271 27.5806H28.4172Z'
                    fill='#00D1FF'
                    style='fill:#00D1FF;fill:color(display-p3 0.0000 0.8196 1.0000);fill-opacity:1;'
                  ></path>
                  <path
                    d='M0.00681122 32.3322C-0.0329235 32.5103 0.106148 32.6786 0.294888 32.6687L10.9934 31.9758C12.9206 31.3126 14.4107 29.6792 14.8279 27.6003V27.5806H5.82795C3.00678 27.5806 0.573031 29.5702 0.00681122 32.3322Z'
                    fill='#6559FF'
                    style='fill:#6559FF;fill:color(display-p3 0.3961 0.3490 1.0000);fill-opacity:1;'
                  ></path>
                  <path
                    d='M42.6227 14.375C39.732 19.285 31.7751 22.9378 27.4539 18.6614C24.5434 15.7807 25.5865 11.8904 27.5235 9.4255C29.4506 6.98042 33.7817 5.30746 36.4142 7.60405C37.1095 8.2079 37.5863 9.00974 37.8545 9.97983C37.934 10.2669 38.2121 10.455 38.5102 10.3956L43.2187 9.49479C43.6558 9.41559 43.9538 9.00974 43.9042 8.56427C43.7452 7.1586 42.9704 4.14926 39.4141 1.90216C37.8644 0.922153 36.0268 0.575684 34.0599 0.575684C32.093 0.575684 30.0964 0.95185 28.2685 1.69429C26.5301 2.40702 25.0202 3.35734 23.7388 4.54523C23.9971 5.17877 24.166 5.86181 24.2355 6.59435C24.3547 7.76245 23.5599 8.81175 22.3977 9.03943L20.3513 9.4255C20.1428 9.92048 19.964 10.4253 19.8149 10.9401C19.9342 11.0093 20.0534 11.0885 20.1825 11.1677C20.9474 11.6825 21.5931 12.3458 22.0897 13.1377C22.954 14.5137 23.3215 16.2262 23.1328 17.9486C22.9738 19.4137 22.4673 20.7897 21.7123 22.0073C24.5633 25.2443 29.4606 26.3233 33.583 25.3433C37.6559 24.3831 43.0597 21.0669 43.785 14.6621C43.8743 13.8702 43.03 13.6921 42.6327 14.3652L42.6227 14.375Z'
                    fill='#293745'
                    style='fill:#293745;fill:color(display-p3 0.1608 0.2157 0.2706);fill-opacity:1;'
                  ></path>
                  <path
                    d='M20.8676 13.8998C20.51 13.3256 20.0431 12.8207 19.457 12.4149C19.4272 12.3951 19.4073 12.3753 19.3775 12.3555C17.5 11.0884 15.116 10.93 13.0299 10.1479C12.3941 9.91045 11.5994 9.58373 11.361 8.91059C11.0531 8.02957 11.6392 7.11885 12.4438 6.72288C12.9107 6.4952 13.5067 6.37641 14.0729 6.37641C14.3511 6.37641 14.6292 6.40611 14.8776 6.4556C15.7914 6.65359 16.318 7.33663 16.4073 8.15826C16.4372 8.43543 16.6954 8.63342 16.9736 8.63342C17.0133 8.63342 17.0431 8.63342 17.0828 8.62351L21.1358 7.85138L22.1291 7.6633C22.5663 7.58411 22.8642 7.18815 22.8145 6.75258C22.7748 6.38632 22.7053 6.03984 22.6159 5.71318C21.5728 1.89211 17.2318 1.12988 15.106 1.12988C12.9802 1.12988 11.2418 1.43676 9.71203 2.06039C8.18224 2.68404 6.97034 3.63436 6.0763 4.93114C5.18227 6.22793 4.73526 7.79199 4.73526 9.61343C4.73526 11.8804 6.16571 13.5137 8.24185 14.3848C9.80146 15.0381 11.51 15.2757 13.1094 15.8201C14.4404 16.2756 15.5332 17.206 14.8279 18.6613C14.3014 19.7501 12.9702 20.2549 11.7981 20.2549C10.0697 20.2549 9.31469 18.8097 9.03655 18.0574C8.95707 17.8297 8.73853 17.6911 8.50013 17.6911C8.46039 17.6911 8.43059 17.6911 8.39085 17.701L3.20547 18.681C2.76839 18.7602 2.47038 19.1661 2.52005 19.6016C2.69886 21.1756 3.42401 22.9178 4.69553 23.9177C6.18558 25.0858 8.22198 25.6698 10.8048 25.6698C12.9305 25.6698 14.818 25.3332 16.447 24.6601C18.3246 23.888 19.8444 22.4922 20.7582 20.7796C21.2451 19.8689 21.5728 18.8592 21.692 17.8C21.841 16.4339 21.5728 15.0381 20.8576 13.8998H20.8676Z'
                    fill='#293745'
                    style='fill:#293745;fill:color(display-p3 0.1608 0.2157 0.2706);fill-opacity:1;'
                  ></path>
                </g>
                <defs>
                  <clipPath id='clip0_201_577'>
                    <rect
                      width='44'
                      height='33.2444'
                      fill='white'
                      style='fill:white;fill-opacity:1;'></rect>
                  </clipPath>
                </defs>
              </svg>
            </div>
            <div class='px-3 py-2 text-xs font-medium rounded-full bg-bg-2 text-tx-0'>
              2021 - 2022
            </div>
          </div>
          <div>
            <h3 class='text-2xl'>
              SafetyCulture Care <span class='ml-1 text-base text-tx-3'>fka Mitti</span>
            </h3>
            <h4 class='text-base'>Principal Product Designer</h4>
          </div>
          <p class='max-w-4xl text-tx-2'>
            Led the 0-to-1 design of SafetyCulture Care's risk mitigation product, establishing the
            UI/UX patterns and remote-first design processes that underpinned the MVP launch.
          </p>
          <p class='max-w-4xl text-tx-2'>
            Hired and managed the design team, providing mentorship, performance development, and
            hands-on leadership to build out the practice from the ground up.
          </p>
        </div>
        <div class='grid grid-cols-6 gap-4'>
          <div class='flex flex-col col-span-3 col-start-1 gap-2 md:col-span-2'>
            <Image
              src={mitti}
              alt='Mitti ui design'
              class='object-cover w-full border border-ui-1 aspect-square rounded-2xl'
              width={390}
              height={390}
              quality={90}
              densities={[2, 3]}
            />
            <div>
              <h4 class='text-sm'>MVP</h4>
              <p class='text-sm text-tx-2'>UX, UI design, brand, strategy</p>
            </div>
          </div>
          <div class='flex flex-col col-span-3 gap-2 md:col-span-2'>
            <Image
              src={mittiRewards}
              alt='Mitti Rewards'
              class='object-cover w-full border border-ui-1 aspect-square rounded-2xl'
              width={390}
              height={390}
              quality={90}
              densities={[2, 3]}
            />
            <div>
              <h4 class='text-sm'>Rewards</h4>
              <p class='text-sm text-tx-2'>Growth design</p>
