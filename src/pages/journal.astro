---
import { getCollection } from 'astro:content'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import BaseLayout from '../layouts/BaseLayout.astro'
import hand from '~/pages/journal/_images/hand.png'

const pageTitle = 'Journal'

function formatDate(raw: Date | string): string {
  const d = typeof raw === 'string' ? new Date(raw) : raw
  const year = d.getFullYear()
  const month = String(d.getMonth() + 1).padStart(2, '0')
  return `${year}.${month}`
}

const allPosts = (await getCollection('journal'))
  .filter((item) => item.data.pubDate)
  .sort((a, b) => {
    const rawA = a.data.updatedDate || a.data.pubDate
    const rawB = b.data.updatedDate || b.data.pubDate
    const dA = typeof rawA === 'string' ? new Date(rawA) : rawA
    const dB = typeof rawB === 'string' ? new Date(rawB) : rawB
    return dB.getTime() - dA.getTime()
  })

const pinned = allPosts.filter((p) => p.data.pinned)
const pinnedIds = new Set(pinned.map((p) => p.id))
// pinned[0] is always shown in featured; pinned[1+] are hidden on md+ in featured
// so exclude pinned[0] from the list, but keep pinned[1+] visible only on mobile
const posts = allPosts.filter((p) => p.id !== pinned[0]?.id)
---

<BaseLayout pageTitle={pageTitle}>
  <!-- Hero: large text top right -->
  <section class='pt-4 system-grid md:pt-8'>
    <div class='col-start-1 col-end-13 pb-12 md:pb-20 lg:col-start-7 lg:pb-20'>
      <h1 class='max-w-sm m-0 text-tx-3 text-h1 md:max-w-xl lg:max-w-3xl'>
        <span class='word-in text-tx-0' style='animation-delay: 0ms'>Thoughts</span>{' '}
        <span class='word-in' style='animation-delay: 60ms'>on</span>{' '}
        <span class='word-in' style='animation-delay: 120ms'>design,</span>{' '}
        <span class='word-in' style='animation-delay: 180ms'>leadership,</span>{' '}
        <span class='word-in' style='animation-delay: 240ms'>and the</span>{' '}
        <span class='word-in' style='animation-delay: 300ms'>occasional</span>{' '}
        <span class='word-in text-tx-0' style='animation-delay: 360ms'>rabbit hole.</span>{' '}
        <span class='word-in' style='animation-delay: 420ms'>
          <Image
            src={hand}
            alt=''
            class='-mt-1 inline-block h-[0.85em] w-auto translate-y-[-0.1em]'
            width={79}
            height={56}
            quality={90}
            densities={[1, 2]}
          />
        </span>
      </h1>
    </div>
  </section>

  <!-- Featured (pinned) articles -->
  {
    pinned.length > 0 && (
      <section class='grid w-full grid-cols-1 gap-6 pb-16 mx-auto max-w-600 md:grid-cols-2 lg:pb-20'>
        {pinned.slice(0, 2).map((post, index) => {
          const date = post.data.updatedDate || post.data.pubDate
          return (
            <a
              href={`/${post.data.slug}/`}
              class={`flex flex-col gap-4 group${index > 0 ? ' hidden md:flex' : ''}`}
            >
              {post.data.ogImage && (
                <div class='overflow-hidden border border-ui-1 aspect-4/3 rounded-xl md:rounded-2xl'>
                  <Image
                    src={post.data.ogImage}
                    alt={post.data.title ?? ''}
                    width={800}
                    height={600}
                    quality={80}
                    densities={[1, 2]}
                    loading={index === 0 ? 'eager' : 'lazy'}
                    fetchpriority={index === 0 ? 'high' : 'auto'}
                    class='h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]'
                  />
                </div>
              )}
              <div class='flex flex-col gap-1'>
                <h2 class='text-xl font-medium lg:text-2xl'>{post.data.title}</h2>
                <div class='flex items-center gap-2 text-sm text-tx-2 lg:text-base'>
                  {date && <span>{formatDate(date)}</span>}
                  {post.data.tags?.map((tag) => (
                    <>
                      <span>·</span>
                      <span class='capitalize'>{tag}</span>
                    </>
                  ))}
                </div>
              </div>
            </a>
          )
        })}
      </section>
    )
  }

  <!-- All posts table -->
  <section class=''>
    <div class='py-2 border-b system-grid border-ui-1'>
      <span class='col-span-3 text-sm text-tx-1 lg:px-3 lg:text-base'>Date</span>
      <span class='hidden col-span-3 text-sm text-tx-1 md:block lg:text-base'>Tags</span>
      <span class='col-span-9 text-sm text-tx-1 md:col-span-6 lg:text-base'>Title</span>
    </div>
    {
      posts.map((post) => {
        const date = post.data.updatedDate || post.data.pubDate
        return (
          <a
            href={`/${post.data.slug}/`}
            class={`group system-grid border-ui-1 hover:bg-bg-2 items-center border-b py-2 transition-colors hover:text-tx-0${pinnedIds.has(post.id) ? ' md:hidden' : ''}`}
          >
            <span class='col-span-3 text-sm text-tx-2 lg:px-3 lg:text-base'>
              {date && formatDate(date)}
            </span>
            <span class='hidden col-span-3 text-sm capitalize text-tx-2 md:block lg:text-base'>
              {post.data.tags?.join(', ') ?? ''}
            </span>
            <span class='col-span-8 text-base font-medium md:col-span-5 lg:text-lg'>
              {post.data.title}
            </span>
            <span class='text-tx-3 col-span-1 flex justify-end transition-transform group-hover:translate-x-0.5 lg:px-3'>
              <Icon name='tabler:arrow-right' class='w-4 h-4' />
            </span>
          </a>
        )
      })
    }
  </section>
</BaseLayout>
