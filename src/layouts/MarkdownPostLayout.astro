---
import BaseLayout from './BaseLayout.astro'
const { frontmatter } = Astro.props

function formatDate(pubDate: Date | string): string {
  const dateObj = typeof pubDate === 'string' ? new Date(pubDate) : pubDate
  const now = new Date()
  const diffTime = now.getTime() - dateObj.getTime()
  const diffDays = Math.floor(diffTime / (1000 * 60 * 60 * 24))
  const diffHours = Math.floor(diffTime / (1000 * 60 * 60))
  const diffMinutes = Math.floor(diffTime / (1000 * 60))

  if (diffTime < 0) {
    const months = [
      'Jan',
      'Feb',
      'Mar',
      'Apr',
      'May',
      'Jun',
      'Jul',
      'Aug',
      'Sep',
      'Oct',
      'Nov',
      'Dec',
    ]
    return `${months[dateObj.getMonth()]} ${dateObj.getDate()}`
  }
  if (diffMinutes < 60 && diffMinutes > 0) return `${diffMinutes}m ago`
  if (diffHours < 24 && diffHours > 0) return `${diffHours}h ago`
  if (diffDays <= 7 && diffDays > 0) return `${diffDays}d ago`

  const months = [
    'Jan',
    'Feb',
    'Mar',
    'Apr',
    'May',
    'Jun',
    'Jul',
    'Aug',
    'Sep',
    'Oct',
    'Nov',
    'Dec',
  ]
  return `${months[dateObj.getMonth()]} ${dateObj.getDate()}, ${dateObj.getFullYear()}`
}

const featureImage = frontmatter.featuredImage || frontmatter.ogImage || frontmatter.image?.url
const featureImageAlt = frontmatter.imageAlt || frontmatter.image?.alt || frontmatter.title || ''
---

<BaseLayout pageTitle={frontmatter.title || 'no title'}>
  <!-- Title: right half, matching journal/index header style -->
  <section class='pt-4 system-grid md:pt-8'>
    <div class='col-start-1 col-end-13 pb-8 lg:col-start-7 lg:pb-12'>
      {
        frontmatter.pubDate && (
          <p class='mb-3 text-sm text-tx-3 lg:text-base'>{formatDate(frontmatter.pubDate)}</p>
        )
      }
      <h1 class='m-0 text-h1 text-tx-0'>{frontmatter.title}</h1>
    </div>
  </section>

  <!-- Feature image: 3/4 page width, right-aligned -->
  {
    featureImage && (
      <section class='pb-10 system-grid lg:pb-16'>
        <div class='col-start-1 col-end-13 lg:col-start-4'>
          <img
            src={featureImage}
            alt={featureImageAlt}
            class='w-full rounded-xl md:rounded-2xl'
            loading='eager'
          />
        </div>
      </section>
    )
  }

  <!-- Content: right 50% -->
  <section class='pb-24 system-grid'>
    <div class='col-start-1 col-end-13 prose prose-slate max-w-none lg:col-start-7'>
      <slot />
    </div>
  </section>
</BaseLayout>
