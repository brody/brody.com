---
import { getCollection } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'

const pageTitle = 'Work'

function formatDate(raw: Date | string): string {
  const d = typeof raw === 'string' ? new Date(raw) : raw
  const year = d.getFullYear()
  const month = String(d.getMonth() + 1).padStart(2, '0')
  return `${year}.${month}`
}

const allPosts = (await getCollection('work'))
  .filter((item) => item.data.pubDate && !item.data.draft)
  .sort((a, b) => {
    const rawA = a.data.updatedDate || a.data.pubDate
    const rawB = b.data.updatedDate || b.data.pubDate
    const dA = typeof rawA === 'string' ? new Date(rawA) : rawA
    const dB = typeof rawB === 'string' ? new Date(rawB) : rawB
    return dB.getTime() - dA.getTime()
  })
---

<BaseLayout pageTitle={pageTitle}>
  <!-- Hero -->
  <section class='pt-4 system-grid md:pt-8'>
    <div class='col-start-1 col-end-13 pb-12 md:pb-20 lg:col-start-7 lg:pb-20'>
      <h1 class='max-w-sm m-0 text-tx-3 text-h1 md:max-w-xl lg:max-w-3xl'>
        <span class='word-in text-tx-0' style='animation-delay: 0ms'>A</span>{' '}
        <span class='word-in' style='animation-delay: 60ms'>selection</span>{' '}
        <span class='word-in' style='animation-delay: 120ms'>of</span>{' '}
        <span class='word-in' style='animation-delay: 180ms'>projects</span>{' '}
        <span class='word-in' style='animation-delay: 240ms'>and</span>{' '}
        <span class='word-in' style='animation-delay: 300ms'>case</span>{' '}
        <span class='word-in text-tx-0' style='animation-delay: 360ms'>studies</span>{' '}
        <span class='word-in' style='animation-delay: 420ms'>from</span>{' '}
        <span class='word-in' style='animation-delay: 480ms'>my</span>{' '}
        <span class='word-in text-tx-0' style='animation-delay: 540ms'>design</span>{' '}
        <span class='word-in' style='animation-delay: 600ms'>career.</span>
      </h1>
    </div>
  </section>

  <!-- All work cards -->
  <section class='grid w-full grid-cols-1 gap-6 pb-16 mx-auto max-w-600 md:grid-cols-2 lg:pb-20'>
    {
      allPosts.map((post, index) => {
        const date = post.data.updatedDate || post.data.pubDate
        const href = post.data.noLink ? undefined : `/work/${post.id}/`
        return (
          <a href={href} class='flex flex-col gap-4 group'>
            {post.data.ogImage && (
              <div class='overflow-hidden border border-ui-1 aspect-4/3 rounded-xl md:rounded-2xl'>
                <img
                  src={post.data.ogImage}
                  alt={post.data.title ?? ''}
                  loading={index === 0 ? 'eager' : 'lazy'}
                  class='h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]'
                />
              </div>
            )}
            <div class='flex flex-col gap-1'>
              <h2 class='text-xl font-medium lg:text-2xl'>{post.data.title}</h2>
              <div class='flex items-center gap-2 text-sm text-tx-2 lg:text-base'>
                {date && <span>{formatDate(date)}</span>}
                {post.data.tags?.map((tag) => (
                  <>
                    <span>·</span>
                    <span class='capitalize'>{tag}</span>
                  </>
                ))}
              </div>
            </div>
          </a>
        )
      })
    }
  </section>
</BaseLayout>
